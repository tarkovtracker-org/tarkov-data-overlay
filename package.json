{
  "name": "tarkov-data-overlay",
  "version": "1.0.0",
  "description": "Community-maintained data overlay for tarkov.dev API corrections and additions",
  "type": "module",
  "scripts": {
    "validate": "tsx scripts/validate.ts",
    "build": "tsx scripts/build.ts",
    "check-overrides": "tsx scripts/check-overrides.ts",
    "eft:compare": "tsx scripts/eft-compare.ts",
    "eft:audit": "tsx scripts/eft-audit.ts",
    "eft:wiki": "tsx scripts/eft-wiki-crosscheck.ts",
    "eft:normalize": "tsx scripts/eft-normalize.ts",
    "eft:story": "mkdir -p data/eft && tsx scripts/eft-story-wiki.ts && tsx scripts/eft-story-generate.ts > data/eft/story-final.json && tsx scripts/eft-story-write.ts",
    "wiki:compare": "tsx scripts/wiki-compare.ts",
    "monitor": "node monitor/server.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{scripts,src/lib,tests,examples}/**/*.ts\"",
    "format:check": "prettier --check \"{scripts,src/lib,tests,examples}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "tarkov",
    "escape-from-tarkov",
    "tarkov-dev",
    "api",
    "overlay",
    "data"
  ],
  "author": "Lab",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ajv": "^8.18.0",
    "json5": "^2.2.3",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
