{
  "$id": "story-chapter.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Story Chapter",
  "description": "Schema for story chapter data in tarkov-data-overlay",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": [
      "id",
      "name",
      "normalizedName",
      "wikiLink",
      "order"
    ],
    "properties": {
      "id": {
        "description": "Unique identifier for the story chapter",
        "type": "string"
      },
      "name": {
        "description": "Display name of the story chapter",
        "type": "string"
      },
      "normalizedName": {
        "description": "URL-friendly normalized name",
        "type": "string"
      },
      "wikiLink": {
        "description": "Link to the official wiki page",
        "type": "string"
      },
      "order": {
        "description": "Sequential display order (1-based)",
        "type": "integer",
        "minimum": 1
      },
      "autoStart": {
        "description": "Whether the chapter starts automatically (true) or must be discovered in-world (false)",
        "type": "boolean"
      },
      "chapterRequirements": {
        "description": "Story chapters that must be completed before this one becomes available",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "name"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "activation": {
        "description": "How this chapter is activated in-world",
        "type": "object",
        "required": ["summary"],
        "properties": {
          "summary": {
            "description": "Short activation summary",
            "type": "string"
          },
          "locations": {
            "description": "Optional map/location hints for activation",
            "type": "array",
            "items": {
              "type": "object",
              "required": ["map", "detail"],
              "properties": {
                "map": { "type": "string" },
                "detail": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "mapUnlocks": {
        "description": "Maps unlocked by completing this chapter (tarkov.dev map IDs)",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "name"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "traderUnlocks": {
        "description": "Traders unlocked by progressing through this chapter (tarkov.dev trader IDs)",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "name"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "description": {
        "description": "Brief description or guidance for the chapter",
        "type": ["string", "null"]
      },
      "notes": {
        "description": "Additional notes (reputation consequences, tips, etc.)",
        "type": ["string", "null"]
      },
      "objectives": {
        "description": "Ordered list of chapter objectives",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "type", "description"],
          "properties": {
            "id": {
              "description": "Globally unique objective ID ({chapter}-{main|opt}-{n})",
              "type": "string"
            },
            "type": {
              "description": "Whether the objective is required or bonus",
              "type": "string",
              "enum": ["main", "optional"]
            },
            "description": {
              "description": "Human-readable objective text",
              "type": "string"
            },
            "maps": {
              "description": "Task-style map references for storyline objective filtering and map display",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "notes": {
              "description": "Optional guidance or tips for this objective",
              "type": ["string", "null"]
            },
            "mutuallyExclusiveWith": {
              "description": "Objective IDs that are mutually exclusive with this objective",
              "type": "array",
              "items": { "type": "string" }
            },
            "count": {
              "description": "Item or action count for the objective",
              "type": "integer",
              "minimum": 1
            },
            "foundInRaid": {
              "description": "Whether any item hand-in must be found in raid",
              "type": "boolean"
            },
            "item": {
              "description": "Primary item for a hand-in or collection objective",
              "type": "object",
              "required": ["id", "name"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "shortName": { "type": "string" }
              },
              "additionalProperties": false
            },
            "items": {
              "description": "Accepted items for a hand-in or collection objective",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "shortName": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "markerItem": {
              "description": "Marker or tool item needed to complete the objective on-map",
              "type": "object",
              "required": ["id", "name"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "shortName": { "type": "string" }
              },
              "additionalProperties": false
            },
            "questItem": {
              "description": "Quest item tied to a map pickup objective",
              "type": "object",
              "required": ["id", "name"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "shortName": { "type": "string" }
              },
              "additionalProperties": false
            },
            "requiredKeys": {
              "description": "Task-style key groups required to access the objective location",
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "name"],
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "shortName": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "zones": {
              "description": "Task-style objective zones with outlines or center points for map markers",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "map": {
                    "type": "object",
                    "required": ["id", "name"],
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" }
                    },
                    "additionalProperties": false
                  },
                  "outline": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["x", "z"],
                      "properties": {
                        "x": { "type": "number" },
                        "y": { "type": "number" },
                        "z": { "type": "number" }
                      },
                      "additionalProperties": false
                    }
                  },
                  "position": {
                    "type": "object",
                    "required": ["x", "z"],
                    "properties": {
                      "x": { "type": "number" },
                      "y": { "type": "number" },
                      "z": { "type": "number" }
                    },
                    "additionalProperties": false
                  },
                  "top": { "type": "number" },
                  "bottom": { "type": "number" }
                },
                "required": ["map"],
                "additionalProperties": false,
                "anyOf": [
                  { "required": ["outline"] },
                  { "required": ["position"] }
                ]
              }
            },
            "possibleLocations": {
              "description": "Task-style point clusters for pickup, visit, or use-objective markers",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["map", "positions"],
                "properties": {
                  "map": {
                    "type": "object",
                    "required": ["id", "name"],
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" }
                    },
                    "additionalProperties": false
                  },
                  "positions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["x", "z"],
                      "properties": {
                        "x": { "type": "number" },
                        "y": { "type": "number" },
                        "z": { "type": "number" }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              }
            },
            "endingId": {
              "description": "Canonical ending this objective is tied to",
              "type": "string",
              "enum": ["savior", "survivor", "fallen", "debtor"]
            },
            "unlocks": {
              "description": "Unlocks tied to objective completion",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "name"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["achievement", "barter", "map", "quest", "trader", "other"]
                  },
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "note": { "type": "string" }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "rewards": {
        "description": "Reward summary for completing the chapter",
        "type": ["object", "null"],
        "properties": {
          "description": {
            "description": "Human-readable reward description",
            "type": "string"
          }
        },
        "required": ["description"],
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
